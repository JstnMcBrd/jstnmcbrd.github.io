---
const navLinks = [
  { label: "About", href: "/#about" },
  { label: "Projects", href: "/#projects" },
];
---

<header class="w-full border-b border-neutral-200 dark:border-neutral-800">
  <nav class="max-w-2xl mx-auto px-6 py-4 flex items-center justify-between">
    <a
      href="/"
      class="font-semibold text-neutral-900 dark:text-neutral-100 hover:text-neutral-600 dark:hover:text-neutral-400 transition-colors"
    >
      Justin McBride
    </a>
    <ul class="flex gap-6 list-none m-0 p-0">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
