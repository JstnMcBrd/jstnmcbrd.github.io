---
import { Icon } from "astro-icon/components";

const socialLinks = [
  {
    label: "GitHub",
    href: "https://github.com/JstnMcBrd",
    icon: "simple-icons:github",
  },
  {
    label: "HuggingFace",
    href: "https://huggingface.co/JstnMcBrd",
    icon: "simple-icons:huggingface",
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/in/jstnmcbrd",
    icon: "simple-icons:linkedin",
  },
  {
    label: "X / Twitter",
    href: "https://x.com/JstnMcBrd",
    icon: "simple-icons:x",
  },
];
---

<header class="w-full border-b border-neutral-200 dark:border-neutral-800">
  <nav class="max-w-2xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/">
      <img src="/favicon.svg" width="20" height="20" alt="Home" />
    </a>
    <ul class="flex gap-5 list-none m-0 p-0">
      {socialLinks.map((link) => (
        <li>
          <a
            href={link.href}
            aria-label={link.label}
            title={link.label}
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral-500 hover:text-neutral-900 dark:text-neutral-500 dark:hover:text-neutral-100 transition-colors"
          >
            <Icon name={link.icon} class="w-4 h-4" />
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
