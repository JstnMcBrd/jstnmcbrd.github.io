---
import { Icon } from 'astro-icon/components';

const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/JstnMcBrd',
    icon: 'simple-icons:github',
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/jstnmcbrd',
    icon: 'simple-icons:linkedin',
  },
  {
    label: 'X / Twitter',
    href: 'https://x.com/JstnMcBrd',
    icon: 'simple-icons:x',
  },
  {
    label: 'GameJolt',
    href: 'https://gamejolt.com/@JustCorp',
    icon: 'simple-icons:gamejolt',
  },
];
---

<footer class="w-full border-t border-neutral-200 dark:border-neutral-800">
  <div class="max-w-2xl mx-auto px-6 py-6 flex items-center justify-center gap-5">
    {socialLinks.map((link) => (
      <a
        href={link.href}
        aria-label={link.label}
        target="_blank"
        rel="noopener noreferrer"
        class="text-neutral-500 hover:text-neutral-900 dark:text-neutral-500 dark:hover:text-neutral-100 transition-colors"
      >
        <Icon name={link.icon} class="w-5 h-5" />
      </a>
    ))}
  </div>
</footer>
