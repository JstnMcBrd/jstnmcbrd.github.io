---
interface Props {
  title: string;
  description: string;
  url?: string | undefined;
  repo?: string | undefined;
  tags: string[];
}

const { title, description, url, repo, tags } = Astro.props;

// Prefer the live URL; fall back to repo if only a repo is provided
const primaryLink = url ?? repo;
---

<article class="py-5 border-b border-neutral-200 dark:border-neutral-800 last:border-0">
  <div class="flex items-baseline justify-between gap-4">
    {primaryLink ? (
      <a
        href={primaryLink}
        target="_blank"
        rel="noopener noreferrer"
        class="font-medium text-neutral-900 dark:text-neutral-100 hover:underline underline-offset-4"
      >
        {title}
      </a>
    ) : (
      <span class="font-medium text-neutral-900 dark:text-neutral-100">{title}</span>
    )}
    {url && repo && (
      <a
        href={repo}
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-neutral-500 dark:text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition-colors shrink-0"
      >
        source
      </a>
    )}
  </div>
  <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
    {description}
  </p>
  {tags.length > 0 && (
    <ul class="mt-2 flex flex-wrap gap-2 list-none p-0 m-0">
      {tags.map((tag) => (
        <li class="text-xs text-neutral-500 dark:text-neutral-500">
          {tag}
        </li>
      ))}
    </ul>
  )}
</article>
